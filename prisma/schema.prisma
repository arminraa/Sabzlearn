generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Course {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  shortDescription String  // Short description for the card
  imageUrl     String
  author       String   // Author name (simple string for now)
  price        Float
  salePrice    Float?   // Optional, null if no discount
  score        Float    @default(0)  // Average rating (0-5)
  viewersCount Int      @default(0)  // Number of views
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

